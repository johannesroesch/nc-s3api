<?xml version="1.0" encoding="UTF-8" ?>
<database xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/database.xsd">

    <!-- In-progress multipart uploads -->
    <table>
        <name>*dbprefix*s3api_multipart_uploads</name>
        <declaration>
            <field>
                <name>id</name>
                <type>integer</type>
                <length>4</length>
                <autoincrement>1</autoincrement>
                <notnull>true</notnull>
            </field>
            <field>
                <name>upload_id</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>bucket</name>
                <type>text</type>
                <length>255</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>object_key</name>
                <type>text</type>
                <length>1024</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>user_id</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>content_type</name>
                <type>text</type>
                <length>255</length>
                <notnull>false</notnull>
            </field>
            <!-- JSON: {"x-amz-meta-foo": "bar", ...} -->
            <field>
                <name>metadata</name>
                <type>text</type>
                <notnull>false</notnull>
            </field>
            <field>
                <name>created_at</name>
                <type>integer</type>
                <length>8</length>
                <notnull>true</notnull>
            </field>
            <index>
                <name>s3api_mpu_upload_id</name>
                <unique>true</unique>
                <field>
                    <name>upload_id</name>
                </field>
            </index>
            <index>
                <name>s3api_mpu_user_bucket</name>
                <field><name>user_id</name></field>
                <field><name>bucket</name></field>
            </index>
        </declaration>
    </table>

    <!-- Individual parts of a multipart upload -->
    <table>
        <name>*dbprefix*s3api_multipart_parts</name>
        <declaration>
            <field>
                <name>id</name>
                <type>integer</type>
                <length>4</length>
                <autoincrement>1</autoincrement>
                <notnull>true</notnull>
            </field>
            <field>
                <name>upload_id</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>part_number</name>
                <type>integer</type>
                <length>4</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>etag</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>size</name>
                <type>integer</type>
                <length>8</length>
                <notnull>true</notnull>
            </field>
            <!-- Nextcloud path to the temporary file holding this part's data -->
            <field>
                <name>tmp_path</name>
                <type>text</type>
                <length>1024</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>created_at</name>
                <type>integer</type>
                <length>8</length>
                <notnull>true</notnull>
            </field>
            <index>
                <name>s3api_mpp_upload_part</name>
                <unique>true</unique>
                <field><name>upload_id</name></field>
                <field><name>part_number</name></field>
            </index>
        </declaration>
    </table>

    <!-- S3 object tags -->
    <table>
        <name>*dbprefix*s3api_object_tags</name>
        <declaration>
            <field>
                <name>id</name>
                <type>integer</type>
                <length>4</length>
                <autoincrement>1</autoincrement>
                <notnull>true</notnull>
            </field>
            <field>
                <name>user_id</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>bucket</name>
                <type>text</type>
                <length>255</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>object_key</name>
                <type>text</type>
                <length>1024</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>tag_key</name>
                <type>text</type>
                <length>128</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>tag_value</name>
                <type>text</type>
                <length>256</length>
                <notnull>true</notnull>
            </field>
            <index>
                <name>s3api_obj_tags_lookup</name>
                <field><name>user_id</name></field>
                <field><name>bucket</name></field>
                <field><name>object_key</name></field>
            </index>
        </declaration>
    </table>

    <!-- S3 bucket tags -->
    <table>
        <name>*dbprefix*s3api_bucket_tags</name>
        <declaration>
            <field>
                <name>id</name>
                <type>integer</type>
                <length>4</length>
                <autoincrement>1</autoincrement>
                <notnull>true</notnull>
            </field>
            <field>
                <name>user_id</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>bucket</name>
                <type>text</type>
                <length>255</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>tag_key</name>
                <type>text</type>
                <length>128</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>tag_value</name>
                <type>text</type>
                <length>256</length>
                <notnull>true</notnull>
            </field>
            <index>
                <name>s3api_bkt_tags_lookup</name>
                <field><name>user_id</name></field>
                <field><name>bucket</name></field>
            </index>
        </declaration>
    </table>

    <!-- Presigned URLs (stored for single-use PUT/DELETE tokens) -->
    <table>
        <name>*dbprefix*s3api_presigned_urls</name>
        <declaration>
            <field>
                <name>id</name>
                <type>integer</type>
                <length>4</length>
                <autoincrement>1</autoincrement>
                <notnull>true</notnull>
            </field>
            <field>
                <name>token</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>user_id</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>bucket</name>
                <type>text</type>
                <length>255</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>object_key</name>
                <type>text</type>
                <length>1024</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>method</name>
                <type>text</type>
                <length>10</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>expires_at</name>
                <type>integer</type>
                <length>8</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>created_at</name>
                <type>integer</type>
                <length>8</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>used</name>
                <type>boolean</type>
                <default>false</default>
                <notnull>true</notnull>
            </field>
            <index>
                <name>s3api_presigned_token</name>
                <unique>true</unique>
                <field><name>token</name></field>
            </index>
        </declaration>
    </table>

    <!-- Per-bucket config blobs (versioning, cors, encryption, acl) -->
    <table>
        <name>*dbprefix*s3api_bucket_metadata</name>
        <declaration>
            <field>
                <name>id</name>
                <type>integer</type>
                <length>4</length>
                <autoincrement>1</autoincrement>
                <notnull>true</notnull>
            </field>
            <field>
                <name>user_id</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>bucket</name>
                <type>text</type>
                <length>255</length>
                <notnull>true</notnull>
            </field>
            <!-- One of: versioning | cors | encryption | acl -->
            <field>
                <name>meta_key</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <!-- JSON blob -->
            <field>
                <name>meta_value</name>
                <type>text</type>
                <notnull>true</notnull>
            </field>
            <field>
                <name>updated_at</name>
                <type>integer</type>
                <length>8</length>
                <notnull>true</notnull>
            </field>
            <index>
                <name>s3api_bkt_meta_unique</name>
                <unique>true</unique>
                <field><name>user_id</name></field>
                <field><name>bucket</name></field>
                <field><name>meta_key</name></field>
            </index>
        </declaration>
    </table>

    <!-- Admin-managed credential pairs (Mode B) -->
    <table>
        <name>*dbprefix*s3api_credentials</name>
        <declaration>
            <field>
                <name>id</name>
                <type>integer</type>
                <length>4</length>
                <autoincrement>1</autoincrement>
                <notnull>true</notnull>
            </field>
            <!-- S3 access key provided to external clients -->
            <field>
                <name>access_key</name>
                <type>text</type>
                <length>128</length>
                <notnull>true</notnull>
            </field>
            <!-- Hashed secret key (bcrypt) -->
            <field>
                <name>secret_key_hash</name>
                <type>text</type>
                <length>255</length>
                <notnull>true</notnull>
            </field>
            <!-- The Nextcloud user whose storage this key-pair maps to -->
            <field>
                <name>nc_user_id</name>
                <type>text</type>
                <length>64</length>
                <notnull>true</notnull>
            </field>
            <field>
                <name>label</name>
                <type>text</type>
                <length>255</length>
                <notnull>false</notnull>
            </field>
            <field>
                <name>created_at</name>
                <type>integer</type>
                <length>8</length>
                <notnull>true</notnull>
            </field>
            <index>
                <name>s3api_creds_access_key</name>
                <unique>true</unique>
                <field><name>access_key</name></field>
            </index>
        </declaration>
    </table>

</database>

{
  "name": "johannesroesch/nc-s3api",
  "description": "S3-compatible API gateway for Nextcloud",
  "type": "nextcloud-app",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Johannes Roesch",
      "email": "johannes.roesch@googlemail.com"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10",
    "nextcloud/ocp": ">=28",
    "phpstan/phpstan": "^2",
    "phpstan/extension-installer": "^1",
    "nextcloud/coding-standard": "^1",
    "infection/infection": "^0.29"
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "infection/extension-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "OCA\\NcS3Api\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OCA\\NcS3Api\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "test:unit": "phpunit --configuration phpunit.xml --testsuite unit",
    "phpstan": "phpstan analyse --no-progress",
    "cs-check": "php-cs-fixer check --diff",
    "cs-fix": "php-cs-fixer fix",
    "infection": "infection --no-progress"
  }
}
